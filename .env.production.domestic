# Spartan Hub 2.0 - Production Environment for Home Use (2 Real Users)
# Copy to .env.production and configure with REAL values

# =============================================================================
# USUARIOS REALES - CONFIGURACIÓN
# =============================================================================

# Usuario 1 (Tú)
PRIMARY_USER_EMAIL=tu-email@real.com
PRIMARY_USER_NAME=Tu Nombre
PRIMARY_USER_PASSWORD=TuPassword123!

# Usuario 2 (Tu mujer)
SECONDARY_USER_EMAIL=email-tu-mujer@real.com
SECONDARY_USER_NAME=Nombre Tu Mujer
SECONDARY_USER_PASSWORD=Password123!

# =============================================================================
# WEARABLES - CONFIGURACIÓN REAL
# =============================================================================

# Garmin (Usuario 1) - https://developer.garmin.com/
GARMIN_CLIENT_ID=tu_garmin_client_id_aqui
GARMIN_CLIENT_SECRET=tu_garmin_client_secret_aqui
GARMIN_REDIRECT_URI=https://tu-dominio.com/api/fitness/garmin/callback

# Apple Health (Usuario 2) - iOS HealthKit
APPLE_HEALTH_KIT_ID=tu_apple_health_kit_id
APPLE_HEALTH_REDIRECT_URI=https://tu-dominio.com/api/fitness/apple/callback

# Google Fit (opcional) - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_REDIRECT_URI=https://tu-dominio.com/api/fitness/google/callback

# =============================================================================
# TERRA - DATOS BIOMÉTRICOS EN TIEMPO REAL
# =============================================================================

# Terra API - https://www.terra.com/ (gratis para testing)
TERRA_API_KEY=tu_terra_api_key_aqui
TERRA_WEBHOOK_SECRET=tu_webhook_secret_generado
WEBHOOK_URL=https://tu-dominio.com/api/terra/webhook

# Qué datos sincronizar
TERRA_SYNC_HRV=true
TERRA_SYNC_HEART_RATE=true
TERRA_SYNC_SLEEP=true
TERRA_SYNC_STEPS=true
TERRA_SYNC_STRESS=true
TERRA_SYNC_SPO2=true

# Frecuencia de sincronización (segundos)
TERRA_SYNC_INTERVAL=300

# =============================================================================
# BASE DE DATOS - CONFIGURACIÓN REAL
# =============================================================================

DATABASE_TYPE=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=spartan_hub_real
POSTGRES_USER=spartan_admin
POSTGRES_PASSWORD=PASSWORD_MUY_SEGURO_AQUI_32_CHARS_MIN
POSTGRES_SSL=false  # true si usas dominio con SSL

# Connection pool
POSTGRES_MAX_CLIENTS=20
POSTGRES_IDLE_TIMEOUT=30000
POSTGRES_CONNECTION_TIMEOUT=10000

# =============================================================================
# REDIS - CACHE EN TIEMPO REAL
# =============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=  # dejar vacío para local, poner password para producción

# =============================================================================
# IA EN TIEMPO REAL - CONFIGURACIÓN
# =============================================================================

# Opción A: Groq Cloud API (gratis, rápido, recomendado)
AI_PROVIDER=groq
GROQ_API_KEY=tu_groq_api_key_aqui  # https://console.groq.com/keys
GROQ_MODEL=llama-3.1-8b-instant
AI_GROQ_TIMEOUT_MS=5000

# Opción B: Ollama Local (más privado, más lento)
# AI_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# AI_MICROSERVICE_TIMEOUT_MS=30000

# Circuit breaker para IA
AI_CB_FAILURE_THRESHOLD=3
AI_CB_RESET_TIMEOUT_MS=60000

# =============================================================================
# ANÁLISIS EN TIEMPO REAL - CONFIGURACIÓN
# =============================================================================

# Cada cuánto analizar datos (segundos)
REALTIME_ANALYSIS_INTERVAL=300  # 5 minutos

# Umbrales de Readiness Score
READINESS_EXCELLENT=80
READINESS_GOOD=60
READINESS_FAIR=40
READINESS_POOR=0

# Umbrales de Estrés
STRESS_HIGH=80
STRESS_MEDIUM=60
STRESS_LOW=40

# Umbrales de Sueño
SLEEP_OPTIMAL_HOURS=8
SLEEP_MINIMUM_HOURS=6
SLEEP_POOR_HOURS=5

# Riesgo de Lesión
INJURY_RISK_HIGH=60
INJURY_RISK_MEDIUM=40
INJURY_RISK_LOW=20

# =============================================================================
# ADAPTACIÓN AUTOMÁTICA DE ENTRENOS
# =============================================================================

WORKOUT_ADAPTATION_ENABLED=true
AUTO_RESCHEDULE_IF_READINESS_LOW=true  # Si readiness < 30%
REDUCE_INTENSITY_IF_READINESS_MEDIUM=true  # Si readiness < 50%
SUGGEST_ACTIVE_RECOVERY=true  # Si estrés > 70%
SUGGEST_REST_DAY=true  # Si sueño < 5 horas

# =============================================================================
# NOTIFICACIONES EN TIEMPO REAL
# =============================================================================

# Email (SendGrid - 100 emails/día gratis)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=tu_sendgrid_api_key_aqui
EMAIL_FROM=spartan-hub@tu-dominio.com
EMAIL_FROM_NAME=Spartan Hub

# Cuándo enviar emails
EMAIL_DAILY_SUMMARY=true
EMAIL_DAILY_SUMMARY_TIME=08:00  # 8 AM

EMAIL_LOW_READINESS=true
EMAIL_HIGH_STRESS=true
EMAIL_POOR_SLEEP=true
EMAIL_WORKOUT_ADAPTED=true

# Telegram (opcional, para alertas inmediatas)
# TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui
# TELEGRAM_CHAT_ID_USER1=tu_chat_id
# TELEGRAM_CHAT_ID_USER2=chat_id_tu_mujer

# =============================================================================
# DOMINIO Y SSL
# =============================================================================

DOMAIN=localhost  # Cambiar a tu-dominio.com si usas dominio público
PORT=3001
HTTPS_PORT=443

SSL_ENABLED=false  # true si usas dominio con SSL
# SSL_CERT_PATH=/etc/ssl/certs/spartan-hub.crt
# SSL_KEY_PATH=/etc/ssl/private/spartan-hub.key

# CORS (qué dominios pueden acceder)
CORS_ORIGIN=http://localhost:5173  # Cambiar a https://tu-dominio.com

# =============================================================================
# SEGURIDAD
# =============================================================================

JWT_SECRET=GENERAR_SECRET_64_CHARS_AQUI_USAR_NODE_CRYPTO
SESSION_SECRET=GENERAR_OTRO_SECRET_64_CHARS_AQUI
COOKIE_SECURE=false  # true si usas HTTPS
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict

CSRF_ENABLED=true
CSRF_COOKIE_SECURE=false  # true si usas HTTPS

# =============================================================================
# LOGGING Y MONITORING
# =============================================================================

LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=production
LOG_FILE_PATH=./logs/production.log
LOG_MAX_SIZE=100m
LOG_MAX_FILES=10

# Health check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/api/health
HEALTH_CHECK_INTERVAL=30000  # 30 segundos

# =============================================================================
# BACKUP AUTOMÁTICO
# =============================================================================

BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000  # 24 horas
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# =============================================================================
# RENDIMIENTO
# =============================================================================

# Rate limiting (peticiones por ventana)
RATE_LIMIT_GLOBAL=1000  # 1000 peticiones cada 15 min
RATE_LIMIT_AUTH=10  # 10 intentos login cada 15 min
RATE_LIMIT_API=500  # 500 peticiones API cada 15 min
RATE_LIMIT_HEAVY_API=50  # 50 peticiones pesadas cada 15 min

# Compresión
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024

# =============================================================================
# IDENTIFICACIÓN DEL ENTORNO
# =============================================================================

NODE_ENV=production
DEPLOYMENT_ENV=home
DEPLOYMENT_REGION=local
SERVICE_NAME=spartan-hub-home
SERVICE_VERSION=2.0.0

# Número de usuarios (2 en este caso)
MAX_USERS=2
IS_PRIVATE_HOME_INSTALL=true
