# Production Environment Configuration
# ⚠️ CRITICAL: Replace all placeholder values with real production secrets
# DO NOT commit the actual .env.production file with real values

# Server Configuration
PORT=3001
NODE_ENV=production

# CORS Configuration (SECURITY: NEVER use '*' with credentials enabled)
# Option 1: Single origin (recommended for most cases)
CORS_ORIGIN=https://your-domain.com

# Option 2: Multiple origins (comma-separated whitelist)
# Uncomment below to use multiple origins instead of CORS_ORIGIN
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://app.your-domain.com

# Database Configuration (Production)
DATABASE_TYPE=postgres
POSTGRES_PRIMARY_HOST=your-prod-db-host
POSTGRES_PRIMARY_PORT=5432
POSTGRES_DB=spartan_hub_prod
POSTGRES_USER=spartan_prod_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PRODUCTION_PASSWORD
POSTGRES_REPLICATION_PASSWORD=REPLACE_WITH_STRONG_REPLICATION_PASSWORD

# Security Configuration (Use strong, unique secrets)
JWT_SECRET=REPLACE_WITH_32_CHAR_MIN_SECRET_KEY
JWT_ALGO=HS256
SESSION_SECRET=REPLACE_WITH_STRONG_SESSION_SECRET

# Logging Configuration
LOG_LEVEL=warn

# AI Service Configuration
AI_SERVICE_URL=https://your-ai-service-url.com
OLLAMA_HOST=https://your-ollama-host:11434

# API Keys for Fitness and Nutrition Services (Production)
API_NINJAS_KEY=REPLACE_WITH_PRODUCTION_API_KEY
EXERCISEDB_KEY=REPLACE_WITH_PRODUCTION_EXERCISE_DB_KEY
EDAMAM_APP_ID=REPLACE_WITH_PRODUCTION_EDAMAM_APP_ID
EDAMAM_APP_KEY=REPLACE_WITH_PRODUCTION_EDAMAM_APP_KEY
FATSECRET_KEY=REPLACE_WITH_PRODUCTION_FATSECRET_KEY
FATSECRET_SECRET=REPLACE_WITH_PRODUCTION_FATSECRET_SECRET

# Additional Production Settings
ENABLE_RATE_LIMITING=true
ENABLE_HELMET_SECURITY=true
ENABLE_CORS=true
