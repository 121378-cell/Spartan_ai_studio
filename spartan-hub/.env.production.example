# Spartan Hub 2.0 - Production Environment Configuration
# Copy this file to .env.production and configure for your production environment
# ⚠️ NEVER commit actual production secrets to version control!

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=production
PORT=3001

# =============================================================================
# CORS CONFIGURATION (SECURITY CRITICAL)
# =============================================================================
# Replace with your actual production domain(s)
# NEVER use '*' in production with credentials!
CORS_ORIGIN=https://your-production-domain.com
# For multiple domains, use comma-separated list:
# CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Option 1: SQLite (Default - Good for small deployments)
DATABASE_TYPE=sqlite
DB_PATH=./data/spartan_hub_production.db

# Option 2: PostgreSQL (Recommended for production)
# Uncomment and configure if using PostgreSQL
# DATABASE_TYPE=postgres
# POSTGRES_HOST=your-db-host.com
# POSTGRES_PORT=5432
# POSTGRES_DB=spartan_hub_prod
# POSTGRES_USER=spartan_prod_user
# POSTGRES_PASSWORD=${POSTGRES_PASSWORD_SECRET}
# POSTGRES_SSL=true

# Connection Pool Settings (PostgreSQL only)
# POSTGRES_MAX_CLIENTS=20
# POSTGRES_IDLE_TIMEOUT=30000
# POSTGRES_CONNECTION_TIMEOUT=10000

# =============================================================================
# REDIS CONFIGURATION (Required for production rate limiting)
# =============================================================================
REDIS_URL=redis://your-redis-host:6379
REDIS_TLS_ENABLED=true
# Redis password (use environment variable or secret manager)
# REDIS_PASSWORD=${REDIS_PASSWORD_SECRET}

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# ⚠️ CRITICAL: Generate strong random secrets for production!
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=${JWT_SECRET_FROM_SECRET_MANAGER}
JWT_ALGO=HS256
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

SESSION_SECRET=${SESSION_SECRET_FROM_SECRET_MANAGER}
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict

# CSRF Protection
CSRF_ENABLED=true
CSRF_COOKIE_SECURE=true

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
# If using custom SSL certificates (not behind reverse proxy)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
# HTTPS_PORT=443

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=production
LOG_FILE_PATH=./logs/production.log
LOG_MAX_SIZE=100m
LOG_MAX_FILES=10

# =============================================================================
# AI SERVICE CONFIGURATION
# =============================================================================
AI_PROVIDER_MODE=single
AI_PROVIDER=groq

# Groq API (Recommended for production)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=${GROQ_API_KEY_FROM_SECRET_MANAGER}
GROQ_MODEL=llama-3.1-8b-instant
AI_GROQ_TIMEOUT_MS=5000

# Circuit Breaker Configuration
AI_CB_FAILURE_THRESHOLD=3
AI_CB_RESET_TIMEOUT_MS=60000
AI_CB_HALF_OPEN_MAX_TRIALS=1

# Fallback to local Ollama if Groq fails
AI_SERVICE_URL=http://localhost:9000
AI_MICROSERVICE_TIMEOUT_MS=30000

# =============================================================================
# API KEYS (External Services)
# =============================================================================
# Configure only the services you need in production
API_NINJAS_KEY=${API_NINJAS_KEY_FROM_SECRET_MANAGER}
EDAMAM_APP_ID=${EDAMAM_APP_ID_FROM_SECRET_MANAGER}
EDAMAM_APP_KEY=${EDAMAM_APP_KEY_FROM_SECRET_MANAGER}
FATSECRET_KEY=${FATSECRET_KEY_FROM_SECRET_MANAGER}
FATSECRET_SECRET=${FATSECRET_SECRET_FROM_SECRET_MANAGER}
EXERCISEDB_KEY=${EXERCISEDB_KEY_FROM_SECRET_MANAGER}

# =============================================================================
# WEARABLE INTEGRATION (OAuth)
# =============================================================================
# Garmin Health API
GARMIN_CLIENT_ID=${GARMIN_CLIENT_ID_FROM_SECRET_MANAGER}
GARMIN_CLIENT_SECRET=${GARMIN_CLIENT_SECRET_FROM_SECRET_MANAGER}
GARMIN_REDIRECT_URI=https://your-domain.com/api/fitness/garmin/callback

# Google Fit API
GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID_FROM_SECRET_MANAGER}
GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET_FROM_SECRET_MANAGER}
GOOGLE_REDIRECT_URI=https://your-domain.com/api/fitness/google/callback

# Apple Health Kit
APPLE_HEALTH_KIT_ID=${APPLE_HEALTH_KIT_ID_FROM_SECRET_MANAGER}
APPLE_REDIRECT_URI=https://your-domain.com/api/fitness/apple/callback

# =============================================================================
# EMAIL CONFIGURATION (Notifications)
# =============================================================================
# SMTP Configuration for sending emails
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=${SMTP_PASSWORD_FROM_SECRET_MANAGER}
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=Spartan Hub

# =============================================================================
# CDN CONFIGURATION (Optional)
# =============================================================================
# CDN URL for static assets (CloudFront, Cloudflare, etc.)
# CDN_URL=https://cdn.your-domain.com
# CDN_ENABLED=false

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# OpenTelemetry / APM Configuration
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-apm-collector.com
# OTEL_SERVICE_NAME=spartan-hub-production
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
# Adjust limits based on your production needs
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_GLOBAL_WINDOW=900
RATE_LIMIT_AUTH=5
RATE_LIMIT_AUTH_WINDOW=900
RATE_LIMIT_API=200
RATE_LIMIT_API_WINDOW=900
RATE_LIMIT_HEAVY_API=20
RATE_LIMIT_HEAVY_API_WINDOW=900

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# Worker threads for CPU-intensive tasks
# WORKER_THREADS=4
# Max memory for Node.js process
# NODE_OPTIONS=--max-old-space-size=4096

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Automatic backup settings
# BACKUP_ENABLED=true
# BACKUP_INTERVAL=86400000
# BACKUP_PATH=./backups/production
# BACKUP_RETENTION_DAYS=30
# BACKUP_REMOTE_ENABLED=false
# BACKUP_REMOTE_PATH=s3://your-bucket/backups

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features in production
# FEATURE_VIDEO_ANALYSIS=true
# FEATURE_AI_COACH=true
# FEATURE_WEARABLE_INTEGRATION=true
# FEATURE_COMMUNITY=false

# =============================================================================
# ENVIRONMENT IDENTIFICATION
# =============================================================================
# Used for logging and monitoring
DEPLOYMENT_ENV=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_INSTANCE=primary
