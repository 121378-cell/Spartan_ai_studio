# Test Environment Configuration
NODE_ENV=test
PORT=3001

# Test Database Configuration (SQLite for tests - using file instead of memory for better isolation)
DB_TYPE=sqlite
DB_PATH=data/test_spartan.db
TEST_DB_PATH=data/test_spartan.db

# JWT Configuration for Tests (minimum 32 characters for security)
JWT_SECRET=a8311656038918446ed12ce0312f23fc8b948526aa9b239a275a11aa15828dc3
JWT_REFRESH_SECRET=12c94773f37e2e418096500b4f918b362113fadbacc78a84cab6a20a31c80499
JWT_ALGO=HS256
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting (disabled for tests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=10
API_RATE_LIMIT_MAX=100
HEAVY_API_RATE_LIMIT_MAX=5

# Redis (disabled for tests)
REDIS_URL=

# Security Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
HELMET_ENABLED=false
CORS_PREFLIGHT_CONTINUE=false
CORS_OPTIONS_SUCCESS_STATUS=204

# Logging (minimal for tests)
LOG_LEVEL=error
ENABLE_REQUEST_LOGGING=false
ENABLE_METRICS=false

# AI Service (mock for tests)
AI_SERVICE_ENABLED=false
AI_PROVIDER=mock

# Alert Configuration
ALERT_SERVICE_ENABLED=false

# Test-specific settings
TEST_TIMEOUT=30000
COVERAGE_THRESHOLD=80

# Disable external services for tests
EXTERNAL_SERVICES_ENABLED=false

# Health check configuration
HEALTH_CHECK_INTERVAL=30000

# Input sanitization
INPUT_SANITIZATION_ENABLED=true
XSS_PROTECTION_ENABLED=true

# Metrics collection (disabled for tests)
METRICS_COLLECTION_ENABLED=false
METRICS_RETENTION_MS=86400000
SESSION_SECRET=be1f1c3af9b3e43756238a1e7f9834649e28bef94a63bae9737ac1ac139a428e
