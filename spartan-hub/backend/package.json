{
  "name": "backend",
  "version": "1.0.0",
  "description": "Spartan Fitness Backend API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "watch": "nodemon --exec ts-node src/server.ts",
    "migrate": "ts-node src/scripts/migrate.ts",
    "init-postgres-schema": "ts-node src/scripts/initPostgresSchema.ts",
    "migrate-to-postgres": "ts-node src/scripts/migrateToPostgres.ts",
    "migrate-preferences": "ts-node src/scripts/migratePreferences.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:security": "jest --testPathPattern='(auth|token)' --collectCoverageFrom='src/**/*.{ts,tsx}' --coverageReporters='text' --coverageReporters='lcov' --coverageDirectory='coverage'",
    "test:coverage:security": "jest --coverage --testPathPattern='(auth|token)' --collectCoverageFrom='src/routes/authRoutes.ts' --collectCoverageFrom='src/routes/tokenRoutes.ts' --collectCoverageFrom='src/middleware/auth.ts' --collectCoverageFrom='src/services/tokenService.ts' --collectCoverageFrom='src/controllers/tokenController.ts'",
    "test:e2e:setup": "ts-node src/scripts/setupE2eDb.ts",
    "test:e2e": "npm run test:e2e:setup && set NODE_ENV=test&& set DATABASE_TYPE=sqlite&& set DB_PATH=data/test_e2e.db&& jest --config jest.e2e.config.js",
    "test:i18n": "ts-node src/scripts/testI18n.ts",
    "test:database": "jest --testPathPattern='database'",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "db:init": "ts-node src/scripts/initDatabase.ts",
    "db:backup": "ts-node src/scripts/backupDatabase.ts",
    "db:restore": "ts-node src/scripts/restoreDatabase.ts",
    "db:verify": "ts-node src/scripts/verifyDatabase.ts",
    "db:optimize": "ts-node src/scripts/optimizeDatabase.ts",
    "db:migrate-performance": "ts-node scripts/migrate-database.ts",
    "db:create-indexes": "sqlite3 data/spartan_hub.db < scripts/create-indexes.sql",
    "db:analyze-performance": "ts-node src/utils/databaseOptimizer.ts",
    "perf:test-load": "ts-node scripts/load-tester.ts",
    "perf:benchmark": "ts-node scripts/performance-benchmark.ts",
    "perf:benchmark-save-baseline": "ts-node scripts/performance-benchmark.ts --save-baseline",
    "perf:start-monitoring": "cd ../ && ./scripts/start-monitoring.sh",
    "perf:monitoring-status": "docker-compose -f ../docker-compose.monitoring.yml ps"
  },
  "keywords": [
    "fitness",
    "backend",
    "api"
  ],
  "author": "Spartan Fitness",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.975.0",
    "@google-cloud/aiplatform": "^6.4.0",
    "@google/generative-ai": "^0.21.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@qdrant/js-client-rest": "^1.16.2",
    "@types/cron": "^2.0.1",
    "@types/csurf": "^1.11.5",
    "@types/dompurify": "3.0.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.5",
    "@types/sanitize-html": "^2.16.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "better-sqlite3-helper": "^3.1.7",
    "compression": "^1.8.1",
    "compute-cosine-similarity": "^1.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron": "^4.4.0",
    "csurf": "^1.11.0",
    "dompurify": "3.3.1",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^170.1.0",
    "helmet": "^8.1.0",
    "i18next": "^23.16.0",
    "i18next-http-backend": "^2.6.1",
    "i18next-http-middleware": "^3.6.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.10.0",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^8.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/helmet": "^0.0.48",
    "@types/i18next": "^13.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.10.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.16.0",
    "@types/redis": "^4.0.10",
    "@types/sqlite3": "^3.1.11",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-standard-with-typescript": "^20.0.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "jest": "^30.2.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
