# Server Configuration
PORT=3001
NODE_ENV=production

# AI Service Configuration
# Mode: 'single' (default) or 'multi' (for cascading fallback)
AI_PROVIDER_MODE=single
# Primary provider when in 'single' mode or first choice in 'multi' mode
# Options: 'microservice' (default), 'groq', 'openai', 'anthropic', 'google'
AI_PROVIDER=microservice

# Multi-Provider Configuration (only used if AI_PROVIDER_MODE=multi or AI_PROVIDER=multi)
AI_PRIMARY_PROVIDER=groq
# Comma-separated list of fallback providers in order of priority
# Note: 'microservice' is always added as the final fallback
AI_FALLBACK_PROVIDERS=openai,anthropic,google

# Circuit Breaker Configuration
# Number of consecutive failures before opening the circuit
AI_CB_FAILURE_THRESHOLD=3
# Time in ms to wait before attempting to use a failed provider again
AI_CB_RESET_TIMEOUT_MS=60000
# Number of successful requests required to close the circuit
AI_CB_HALF_OPEN_MAX_TRIALS=1

# Provider-Specific Configuration
# Groq
GROQ_API_KEY=your_groq_api_key_here
AI_GROQ_TIMEOUT_MS=5000
# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
AI_OPENAI_TIMEOUT_MS=5000
# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_ANTHROPIC_TIMEOUT_MS=5000
# Google/Gemini
GEMINI_API_KEY=your_gemini_api_key_here
AI_GOOGLE_TIMEOUT_MS=5000

# Microservice (Ollama) Configuration
# Required if AI_PROVIDER=microservice or as fallback
AI_SERVICE_URL=http://localhost:9000
AI_MICROSERVICE_TIMEOUT_MS=30000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Database Configuration
DATABASE_TYPE=postgres

# Primary Database (Write)
POSTGRES_PRIMARY_HOST=localhost
POSTGRES_PRIMARY_PORT=5433
POSTGRES_DB=spartan_fitness
POSTGRES_USER=spartan_user
POSTGRES_PASSWORD=your_secure_password_here

# Read Replicas (Read)
POSTGRES_REPLICA_1_HOST=localhost
POSTGRES_REPLICA_1_PORT=5434
POSTGRES_REPLICA_2_HOST=localhost
POSTGRES_REPLICA_2_PORT=5435

# Connection Pool
POSTGRES_MAX_CLIENTS=10
POSTGRES_IDLE_TIMEOUT=30000
POSTGRES_CONNECTION_TIMEOUT=2000
POSTGRES_MAX_USES=7500

# Read Replica Config
ENABLE_READ_REPLICAS=true
READ_REPLICA_STRATEGY=round-robin

# Security Configuration
# Generate new secrets for production!
JWT_SECRET=your_jwt_secret_here
JWT_ALGO=HS256
SESSION_SECRET=your_session_secret_here
