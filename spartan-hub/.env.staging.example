# Spartan Hub 2.0 - Staging Environment Configuration
# Copy this file to .env.staging for staging environment
# Staging should mirror production as closely as possible

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=staging
PORT=3001

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGIN=https://staging.your-domain.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_TYPE=postgres
POSTGRES_HOST=staging-db.your-domain.com
POSTGRES_PORT=5432
POSTGRES_DB=spartan_hub_staging
POSTGRES_USER=spartan_staging_user
POSTGRES_PASSWORD=${POSTGRES_PASSWORD_FROM_SECRET_MANAGER}
POSTGRES_SSL=require

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://staging-redis.your-domain.com:6379
REDIS_TLS_ENABLED=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET=${JWT_SECRET_FROM_SECRET_MANAGER}
JWT_ALGO=HS256
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

SESSION_SECRET=${SESSION_SECRET_FROM_SECRET_MANAGER}
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=.staging.your-domain.com

CSRF_ENABLED=true
CSRF_COOKIE_SECURE=true

# =============================================================================
# AI SERVICE CONFIGURATION
# =============================================================================
AI_PROVIDER_MODE=single
AI_PROVIDER=groq
GROQ_API_KEY=${GROQ_API_KEY_FROM_SECRET_MANAGER}
GROQ_MODEL=llama-3.1-8b-instant

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=debug
LOG_FORMAT=production

# =============================================================================
# ENVIRONMENT IDENTIFICATION
# =============================================================================
DEPLOYMENT_ENV=staging
DEPLOYMENT_REGION=us-east-1
