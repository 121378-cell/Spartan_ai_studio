npx lint-staged

# ─── Secret scanning ─────────────────────────────────────────────────────────
# Block commits containing real API keys / tokens
SECRETS_FOUND=0

check_secret() {
  local pattern="$1"
  local label="$2"
  if git diff --cached --unified=0 | grep -E "^\+" | grep -qE "$pattern"; then
    echo ""
    echo "🚨  BLOCKED: Possible $label detected in staged files!"
    echo "    Remove the secret before committing."
    echo ""
    SECRETS_FOUND=1
  fi
}

# Groq API Key  (gsk_ followed by 50+ alphanumeric chars)
check_secret 'gsk_[A-Za-z0-9]{40,}' "Groq API Key"

# OpenAI API Key
check_secret 'sk-[A-Za-z0-9]{40,}' "OpenAI API Key"

# Generic high-entropy strings that look like secrets (key= followed by 30+ chars, not a placeholder)
check_secret '(API_KEY|SECRET|TOKEN|PASSWORD)\s*=\s*[A-Za-z0-9+/]{30,}' "generic secret"

if [ "$SECRETS_FOUND" -ne 0 ]; then
  echo "❌  Commit aborted due to secret detection."
  echo "    If this is a false positive, add the file pattern to .gitignore"
  echo "    or prefix the value with 'your_' to mark it as a placeholder."
  exit 1
fi
# ─────────────────────────────────────────────────────────────────────────────
