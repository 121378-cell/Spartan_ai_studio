{
  "name": "spartan-hub",
  "version": "1.0.0",
  "description": "Fitness coaching application with AI integration",
  "main": "scripts/simple-launcher.js",
  "scripts": {
    "prepare": "husky install",
    "build:frontend": "vite build",
    "build:backend": "cd backend && npx tsc",
    "build:services": "npx tsc src/services/fitnessNutritionService.ts --outDir dist/services",
    "build:all": "npm run build:frontend && npm run build:backend && npm run build:services",
    "start:frontend": "vite preview",
    "start:backend": "cd backend && npm start",
    "dev": "concurrently \"vite\" \"cd backend && npm run dev\"",
    "start": "node scripts/simple-launcher.js",
    "build:exe": "npm run build:all && pkg scripts/simple-launcher.js -t node18-win-x64 -o scripts/dist/spartan-hub.exe",
    "build:full": "npm run build:all && node scripts/create-dist.js",
    "test:env": "node -r ts-node/register scripts/test-env-config.js",
    "test:fitness": "node -r ts-node/register scripts/test-fitness-nutrition-service.js",
    "test": "npm run test:node && npm run test:components",
    "test:node": "jest --config scripts/config/jest.config.js",
    "test:components": "jest --config scripts/config/jest.config.components.js",
    "test:frontend": "npm run test:node && npm run test:components",
    "test:backend": "cd backend && npm test",
    "test:all": "npm run test:frontend && npm run test:backend",
    "test:coverage": "npm run test:node -- --coverage && npm run test:components -- --coverage",
    "lint": "eslint src scripts vite.config.ts --ext .ts,.tsx --config scripts/config/.eslintrc.mjs",
    "type-check": "tsc --noEmit",
    "security-audit": "npm audit --audit-level=high",
    "backup:run": "node scripts/backupDatabase.js",
    "backup:schedule": "node scripts/scheduleBackup.js",
    "backup:status": "node scripts/checkBackupStatus.js",
    "backup:test": "node scripts/testBackup.js",
    "docker:up": "docker-compose -f scripts/docker/docker-compose.yml up -d --build",
    "docker:down": "docker-compose -f scripts/docker/docker-compose.yml down",
    "docker:status": "docker-compose -f scripts/docker/docker-compose.yml ps",
    "docker:logs": "docker-compose -f scripts/docker/docker-compose.yml logs -f",
    "test:backend-suite": "cd backend && npm run build && node dist/testDatabase.js && node dist/testAiService.js && node dist/test.js",
    "dist": "node scripts/create-dist.js",
    "verify:secrets": "node scripts/verifySecrets.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mediapipe/tasks-vision": "^0.10.32",
    "@mui/material": "^7.3.5",
    "@sinclair/typebox": "^0.34.41",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/dompurify": "3.0.5",
    "@types/sanitize-html": "^2.16.0",
    "axios": "^1.6.0",
    "dompurify": "3.3.1",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "framer-motion": "^12.31.0",
    "immer": "^10.1.3",
    "lucide-react": "^0.562.0",
    "node-cron": "^4.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "readline-sync": "^1.4.10",
    "sanitize-html": "^2.17.0",
    "three": "^0.180.0",
    "uuid": "^13.0.0"
  },
  "author": "Spartan Hub Team",
  "license": "MIT",
  "engines": {
    "node": "18.x"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@jest/globals": "^30.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.8.1",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@yao-pkg/pkg": "^6.11.0",
    "babel-jest": "^30.2.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.3.0",
    "jsonwebtoken": "^9.0.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.18"
  },
  "bin": "simple-launcher.js",
  "pkg": {
    "assets": [
      "dist/**/*",
      "backend/dist/**/*",
      "data/**/*",
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist-exe"
  }
}
