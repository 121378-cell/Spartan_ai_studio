# Example .env file for Spartan Hub
# Copy this file to .env and fill in your actual values
# Never commit the actual .env file with real values

# Server Configuration
PORT=3001                            # Port for the backend server to listen on
NODE_ENV=development                 # Environment: development, production, or test

# CORS Configuration (SECURITY: NEVER use '*' with credentials enabled)
# Option 1: Single origin (recommended for most cases)
CORS_ORIGIN=http://localhost:5173   # Frontend URL for CORS configuration

# Option 2: Multiple origins (comma-separated whitelist)
# Uncomment below to use multiple origins instead of CORS_ORIGIN
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-dev-domain.com

# Database Configuration
DB_HOST=localhost                    # MongoDB host
DB_PORT=27017                       # MongoDB port
DB_NAME=spartan_hub                 # MongoDB database name
DB_PASSWORD=                        # MongoDB password (required in production)
DB_URL=mongodb://localhost:27017    # Full MongoDB connection URL

# Security Configuration
JWT_SECRET=                         # Secret key for JWT token generation (min 32 chars)
JWT_ALGO=HS256                      # JWT signing algorithm (HS256, RS256, etc.)
SESSION_SECRET=                     # Session secret for cookie signing (min 32 chars)

# Logging Configuration
LOG_LEVEL=info                      # Logging level: debug, info, warn, error

# API Keys for Fitness and Nutrition Services
# Sign up at the respective services to get your free API keys

# API Ninjas - https://api-ninjas.com/
API_NINJAS_KEY=your_api_ninjas_key_here

# Edamam Nutrition API - https://www.edamam.com/
EDAMAM_APP_ID=your_edamam_app_id_here
EDAMAM_APP_KEY=your_edamam_app_key_here

# FatSecret Platform API - https://platform.fatsecret.com/
FATSECRET_KEY=your_fatsecret_key_here
FATSECRET_SECRET=your_fatsecret_secret_here

# ExerciseDB API via RapidAPI - https://rapidapi.com/
EXERCISEDB_KEY=your_exercisedb_key_here

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# AI Provider Configuration
# Options: microservice (default), groq, local
AI_PROVIDER=groq

# Groq API Configuration
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=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
GROQ_MODEL=llama3-8b-8192