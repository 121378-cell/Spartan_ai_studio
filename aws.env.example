# =============================================================================
# AWS Environment Configuration Template
# Spartan Hub 2.0 - Staging Environment
# =============================================================================
#
# Copy this file to aws.env and fill in your values.
# NEVER commit aws.env to version control - it contains sensitive data!
#
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------

# AWS Account ID (required)
AWS_ACCOUNT_ID=

# AWS Region (default: us-east-1)
AWS_REGION=us-east-1

# AWS Profile (optional, for local development)
AWS_PROFILE=

# -----------------------------------------------------------------------------
# Terraform Backend Configuration
# -----------------------------------------------------------------------------

# S3 bucket for Terraform state (must be created manually first)
TERRAFORM_STATE_BUCKET=spartan-hub-terraform-state-staging

# DynamoDB table for state locking (must be created manually first)
TERRAFORM_LOCK_TABLE=spartan-hub-terraform-locks-staging

# State file key within the bucket
TERRAFORM_STATE_KEY=staging/infrastructure/terraform.tfstate

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Project name (used for resource tagging)
PROJECT_NAME=spartan-hub

# Environment name
ENVIRONMENT=staging

# Domain name for the application (optional)
DOMAIN_NAME=

# SSL Certificate ARN from ACM (optional, for HTTPS)
SSL_CERTIFICATE_ARN=

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# RDS PostgreSQL database name
DB_NAME=spartan_hub

# RDS PostgreSQL master username
DB_USERNAME=spartan_admin

# RDS PostgreSQL master password (REQUIRED - generate a strong password)
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------

# Email address for CloudWatch alarm notifications
SNS_ALARM_EMAIL=

# Slack webhook URL for notifications (optional)
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# GitHub Actions Secrets (for CI/CD)
# -----------------------------------------------------------------------------

# These values need to be configured as GitHub repository secrets:
#
# AWS_ACCOUNT_ID - Your AWS account ID
# TERRAFORM_STATE_BUCKET - S3 bucket for Terraform state
# TERRAFORM_LOCK_TABLE - DynamoDB table for state locking
# DEPLOYMENT_BUCKET - S3 bucket for deployment artifacts
# SLACK_WEBHOOK_URL - Slack webhook for notifications
#
# Additionally, configure an OIDC role in AWS with trust relationship:
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Principal": {
#         "Federated": "arn:aws:iam::ACCOUNT_ID:oidc-provider/token.actions.githubusercontent.com"
#       },
#       "Action": "sts:AssumeRoleWithWebIdentity",
#       "Condition": {
#         "StringEquals": {
#           "token.actions.githubusercontent.com:aud": "sts.amazonaws.com"
#         },
#         "StringLike": {
#           "token.actions.githubusercontent.com:sub": "repo:ORG/REPO:*"
#         }
#       }
#     }
#   ]
# }

# -----------------------------------------------------------------------------
# Cost Center and Tags
# -----------------------------------------------------------------------------

# Team responsible for this infrastructure
OWNER_TEAM=platform-team

# Cost center for billing
COST_CENTER=engineering

# Additional tags (JSON format)
ADDITIONAL_TAGS={}

# -----------------------------------------------------------------------------
# Instance Configuration
# -----------------------------------------------------------------------------

# Frontend EC2 instance type
FRONTEND_INSTANCE_TYPE=t3.medium

# Backend EC2 instance type
BACKEND_INSTANCE_TYPE=t3.medium

# RDS instance class
RDS_INSTANCE_CLASS=db.t3.micro

# Redis node type
REDIS_NODE_TYPE=cache.t3.micro

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------

# VPC CIDR block
VPC_CIDR=10.0.0.0/16

# Public subnet CIDRs (comma-separated)
PUBLIC_SUBNET_CIDRS=10.0.1.0/24,10.0.2.0/24

# Private subnet CIDRs (comma-separated)
PRIVATE_SUBNET_CIDRS=10.0.10.0/24,10.0.11.0/24

# Availability zones (comma-separated)
AVAILABILITY_ZONES=us-east-1a,us-east-1b

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------

# Enable encryption for all resources
ENABLE_ENCRYPTION=true

# Enable VPC Flow Logs
ENABLE_FLOW_LOGS=false

# Enable WAF for ALB
ENABLE_WAF=false

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------

# RDS backup retention period (days)
RDS_BACKUP_RETENTION=7

# RDS skip final snapshot (set to false for production)
RDS_SKIP_FINAL_SNAPSHOT=false

# RDS deletion protection (set to true for production)
RDS_DELETION_PROTECTION=false
