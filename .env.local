# =============================================================================
# Spartan Hub 2.0 - Local Test Environment Configuration
# =============================================================================
# Copy this file to .env.local for local development
# DO NOT commit this file with real credentials
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------

CORS_ORIGIN=http://localhost:5173
# For multiple origins, use ALLOWED_ORIGINS instead:
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# -----------------------------------------------------------------------------

DATABASE_TYPE=postgres

# Primary Database
POSTGRES_PRIMARY_HOST=localhost
POSTGRES_PRIMARY_PORT=5432
POSTGRES_DB=spartan_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password

# Connection Pool
POSTGRES_MAX_CLIENTS=10
POSTGRES_IDLE_TIMEOUT=30000
POSTGRES_CONNECTION_TIMEOUT=2000

# Read Replicas (disabled for local test)
ENABLE_READ_REPLICAS=false

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# QDRANT VECTOR DATABASE CONFIGURATION
# -----------------------------------------------------------------------------

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# AI SERVICE CONFIGURATION
# -----------------------------------------------------------------------------

# AI Provider Mode: 'single' or 'multi'
AI_PROVIDER_MODE=single

# Primary AI Provider: 'microservice', 'groq', 'openai', 'anthropic', 'google'
AI_PROVIDER=microservice

# Microservice (Ollama) Configuration
AI_SERVICE_URL=http://localhost:8000
AI_MICROSERVICE_TIMEOUT_MS=30000

# Ollama Direct Configuration (optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2:2b

# Groq Configuration (if using)
GROQ_API_KEY=your_groq_api_key_here
AI_GROQ_TIMEOUT_MS=5000

# OpenAI Configuration (if using)
OPENAI_API_KEY=your_openai_api_key_here
AI_OPENAI_TIMEOUT_MS=5000

# Anthropic Configuration (if using)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_ANTHROPIC_TIMEOUT_MS=5000

# Google/Gemini Configuration (if using)
GEMINI_API_KEY=your_gemini_api_key_here
AI_GOOGLE_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION (LOCAL TEST VALUES)
# -----------------------------------------------------------------------------

# WARNING: These are for LOCAL TESTING ONLY!
# Generate new secrets for production!

JWT_SECRET=local_test_jwt_secret_min_32_chars_for_security
JWT_ALGO=HS256
SESSION_SECRET=local_test_session_secret_min_32_chars

# -----------------------------------------------------------------------------
# TERRA INTEGRATION (MOCK)
# -----------------------------------------------------------------------------

TERRA_MOCK_ENABLED=true
TERRA_MOCK_URL=http://localhost:8080
TERRA_WEBHOOK_SECRET=local_test_webhook_secret

# -----------------------------------------------------------------------------
# MEDIAPIPE CONFIGURATION
# -----------------------------------------------------------------------------

MEDIAPIPE_SERVICE_URL=http://localhost:8001
MEDIAPIPE_ENABLED=true

# -----------------------------------------------------------------------------
# CACHE CONFIGURATION
# -----------------------------------------------------------------------------

CACHE_ENABLED=true
CACHE_TTL=3600

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# FILE UPLOAD CONFIGURATION
# -----------------------------------------------------------------------------

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (Optional - for local testing)
# -----------------------------------------------------------------------------

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@spartan-hub.local.test
EMAIL_ENABLED=false

# -----------------------------------------------------------------------------
# MONITORING CONFIGURATION
# -----------------------------------------------------------------------------

METRICS_ENABLED=true
METRICS_PATH=/metrics
TRACING_ENABLED=false

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------

FEATURE_AI_COACHING=true
FEATURE_BIOMETRICS=true
FEATURE_CHALLENGES=true
FEATURE_ACHIEVEMENTS=true
FEATURE_SOCIAL=false
FEATURE_VIDEO_ANALYSIS=true

# -----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS
# -----------------------------------------------------------------------------

DEBUG_MODE=true
HOT_RELOAD=true
MOCK_MODE=true
